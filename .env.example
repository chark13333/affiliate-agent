# ===== LINE Bot =====
# สร้างที่ https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# ===== Claude API =====
# สร้างที่ https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# ===== Lazada Affiliate =====
# สมัครที่ https://open.lazada.com (Developer) + https://affiliate.lazada.co.th (Affiliate)
LAZADA_APP_KEY=your_lazada_app_key
LAZADA_APP_SECRET=your_lazada_app_secret
LAZADA_TRACKING_ID=your_tracking_id  # ได้จาก Lazada Affiliate Dashboard

# ===== Shopee Affiliate =====
# สมัครที่ https://open.shopee.com (Partner) + https://affiliate.shopee.co.th (Affiliate)
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
SHOPEE_AFFILIATE_ID=your_affiliate_id
